{
   "$schema": "https://opencode.ai/config.json",
   "server": {
      "port": 4096,
      "hostname": "0.0.0.0",
      "mdns": true,
      "cors": ["http://localhost:5173"]
   },
   "autoupdate": "notify",
   "compaction": {
      "auto": true,
      "prune": true,
      "reserved": 10000
   },
   "watcher": {
"ignore": [
          "./node_modules/**",
          ".git/**",
          "./readme/**",
          "./README.md"
       ]
   },
   "share": "disabled"
}
